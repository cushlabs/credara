# syntax=docker/dockerfile:1
#
# Creda clients image. Multi-stage:
#   1. node:20 (pnpm) — install deps + tsc + vite build
#   2. nginx-unprivileged — serve dist/ with SPA history fallback
#
# Build context = repo root (matches testbed/images/*.Dockerfile pattern):
#   docker build -f clients/Dockerfile -t creda-clients:testbed .

ARG NODE_BUILDER=docker.io/library/node:20-alpine
# nginxinc/nginx-unprivileged is the upstream's purpose-built non-root variant:
#   - runs as uid 101 by default (matches the chart's runAsUser)
#   - listens on :8080 instead of :80 so it doesn't need CAP_NET_BIND_SERVICE
#   - writes the pid file under /tmp instead of /var/run/, so a read-only or
#     restricted-PSS-locked /var/run/ doesn't break startup
ARG RUNTIME=docker.io/nginxinc/nginx-unprivileged:1.27-alpine

FROM ${NODE_BUILDER} AS builder
RUN apk add --no-cache git
RUN corepack enable && corepack prepare pnpm@9.7.0 --activate
WORKDIR /src
COPY clients/package.json clients/pnpm-lock.yaml* ./
# `--ignore-scripts` keeps the install fast; playwright browsers aren't needed in the
# production image (they ship as part of the e2e container).
RUN pnpm install --frozen-lockfile --ignore-scripts || pnpm install --ignore-scripts
COPY clients/ ./
# Build-time fallback only — the SPA reads window.__CREDA_FHIR_BASE__ at runtime from
# /tmp/runtime-config.js generated by docker-entrypoint.sh, which always wins. This is
# what `pnpm dev` (no nginx, no entrypoint) sees.
ARG VITE_FHIR_BASE=mock
ENV VITE_FHIR_BASE=${VITE_FHIR_BASE}
RUN pnpm build

FROM ${RUNTIME}
# Static SPA bundle and static nginx config. Both are immutable in this image — the
# entrypoint never modifies them. Runtime config lives in /tmp (always writable). See
# clients/docker-entrypoint.sh and clients/nginx.conf for the contract between them.
COPY --from=builder /src/dist /usr/share/nginx/html
COPY clients/nginx.conf /etc/nginx/conf.d/default.conf
COPY clients/docker-entrypoint.sh /docker-entrypoint.d/40-creda.sh
# The entrypoint script must be executable. We chmod once at build time (as root) so the
# runtime non-root user can exec it. The upstream image's entrypoint walks
# /docker-entrypoint.d/*.sh in lex order and runs each one that has +x.
USER root
RUN chmod +x /docker-entrypoint.d/40-creda.sh
USER 101
EXPOSE 8080
HEALTHCHECK --interval=10s --timeout=2s --start-period=5s --retries=3 \
  CMD wget -qO- http://127.0.0.1:8080/healthz || exit 1
# Use the upstream image's default entrypoint, which executes /docker-entrypoint.d/*.sh in
# lex order before exec'ing nginx. Our 40-creda.sh writes /tmp/runtime-config.js and the
# optional /tmp/fhir-overrides.d/fhir.conf, both of which the static default.conf above
# references at request time.
