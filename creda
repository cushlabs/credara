#!/usr/bin/env bash
#
# creda — thin dispatcher for Creda dev commands. Each subcommand maps to a Makefile target,
# so the Makefile stays the single source of truth. Works from anywhere: it locates the repo
# from the script's own location.
#
# Put it on your PATH so `creda anchor` works globally, e.g.:
#   ln -s "$(pwd)/creda" /usr/local/bin/creda      # or ~/.local/bin/creda (on your PATH)
# or add a shell alias to ~/.zshrc:
#   alias creda="$(pwd)/creda"
#
# The only host prerequisite is Docker (see docs/DEVELOPMENT.md).
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cmd="${1:-help}"
[ "$#" -gt 0 ] && shift || true

case "$cmd" in
  anchor)
    # The known-good full run: workspace tests, single-threaded (bounded memory).
    exec make -C "$ROOT" anchor
    ;;
  help | -h | --help | "")
    cat <<'EOF'
creda — Creda dev commands (a thin wrapper over `make`)

Usage: creda <command>

  anchor      Run the full workspace test suite single-threaded — the known-good run
              (= make test JOBS=1). Safe on a memory-limited Docker VM.
  test        Full workspace test suite.
  test-fast   Ed25519-only fast path (no pqcrypto / RocksDB C build).
  ci          fmt-check + clippy + test (everything CI gates on).
  fmt         Apply rustfmt.
  clippy      Lint with warnings-as-errors.
  build       Release build of the workspace.
  shell       Open a shell in the dev container.
  clean       Remove build artifacts and the dependency cache.

Any other command is passed through to `make`. The only host prerequisite is Docker.
EOF
    ;;
  *)
    # Pass through to make (e.g., `creda <some-target>`).
    exec make -C "$ROOT" "$cmd" "$@"
    ;;
esac
