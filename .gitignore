# ---- Rust ----
/target
**/target
*.rs.bk
# In-repo Cargo cache used by the Docker dev workflow (make / devcontainer).
/.cargo-cache/
# Cargo.lock IS committed for the workspace (binaries + reproducible builds).
# If a member crate is a pure library published to crates.io, it may ignore its own lock.

# ---- Java / Kotlin / Gradle (bridge/) ----
bridge/build/
bridge/.gradle/
bridge/.kotlin/
# In-repo Gradle/Maven cache used by the Dockerized `make bridge` build.
/.gradle-cache/
**/build/
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
.gradletasknamecache

# ---- Node (tooling, docs rendering) ----
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Secrets / credentials (NEVER commit) ----
*.pem
*.key
*.p12
*.pfx
*.jks
.env
.env.*
!.env.example
secrets/
*-credentials.*
*.kubeconfig

# ---- Synthetic / generated data (regenerate from the M9 generator) ----
/data/
*.ndjson
!conformance/**/fixtures/**

# ---- Build / packaging output ----
/dist/
*.tar.gz
charts/*.tgz

# ---- Cowork handoff files (kept locally, not tracked) ----
docs/GITHUB_SETUP.md

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ---- Vite / Playwright / sandbox temp ----
# Vite writes timestamped temp configs next to vite.config.ts during HMR.
**/vite.config.ts.timestamp-*.mjs
# Playwright per-run output (already in clients/.gitignore, restated here so
# git status is clean if Playwright is run outside clients/ too).
**/playwright-report/
**/test-results/
# Sandbox-side scratch artifacts (Claude's Read/Write tooling occasionally
# leaves 0-byte _tmp_* files in the mount that can't be unlinked from inside).
_tmp_*
**/_tmp_*
