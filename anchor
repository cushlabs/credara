#!/usr/bin/env bash
#
# anchor — settle a project into a known-good state by running its complete gate (lint + test).
#
#   anchor creda   The complete local gate — fmt + clippy (workspace + grpc + libp2p) + the whole
#                  test suite — single-threaded so the RocksDB from-source compile stays within a
#                  memory-limited Docker VM (no OOM). Mirrors ci-rust: a clean run = a green CI.
#                  Run it before every commit. Equivalent to `make anchor`.
#
# The only host prerequisite is Docker (see docs/DEVELOPMENT.md). Put `anchor` on your PATH so
# `anchor creda` works from anywhere, e.g.:
#   ln -s "$(pwd)/anchor" /usr/local/bin/anchor      # or ~/.local/bin/anchor (on your PATH)
# or add a shell alias to ~/.zshrc:
#   alias anchor="$(pwd)/anchor"
set -euo pipefail

# Resolve the script's real location, following symlinks, so `anchor` works when symlinked onto
# PATH. Portable for macOS bash 3.2 (no `readlink -f`).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$DIR/$SOURCE" ;; esac
done
ROOT="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

target="${1:-}"
case "$target" in
  creda)
    echo "⚓ Anchoring Creda — full local gate (fmt + clippy + tests, mirrors ci-rust), single-threaded…"
    exec make -C "$ROOT" anchor
    ;;
  "" | -h | --help | help)
    cat <<'EOF'
anchor — settle a project into a known-good state (definitive build + test).

Usage:
  anchor creda    The complete pre-commit gate — fmt + clippy (workspace + grpc + libp2p) + the
                  whole test suite, single-threaded (bounded memory; avoids the RocksDB OOM).
                  Mirrors ci-rust, so a clean run means a green CI.

Faster inner-loop targets from the repo root: make test (workspace tests only), make fmt
(auto-format), make clippy, make shell. `make ci` is this same gate as discrete targets.
See docs/DEVELOPMENT.md.
EOF
    ;;
  *)
    echo "anchor: unknown target '$target' (did you mean 'anchor creda'?)" >&2
    exit 2
    ;;
esac
