# Code owners for Creda.
#
# Order matters: later rules override earlier ones.
# Replace @cushlabs/<team> handles with real GitHub teams or usernames before
# enabling "Require review from Code Owners" in branch protection.
#
# Docs: https://docs.github.com/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# Default owner — catches anything not matched below.
*                                       @cushlabs/maintainers

# ---- Dependency spine (M1 -> M5) ----
/crates/creda-events/                   @cushlabs/m1-events
/crates/creda-store/                    @cushlabs/m2-store
/crates/creda-graph/                    @cushlabs/m3-graph
/crates/creda-net/                      @cushlabs/m4-net
/crates/creda-core/                     @cushlabs/m5-core

# ---- Adjacent components ----
/crates/creda-export-gate/              @cushlabs/export-gate
/crates/creda-verifier/                 @cushlabs/verifier
/bridge/                                @cushlabs/bridge
/conformance/                           @cushlabs/conformance
/testbed/                               @cushlabs/testbed
/tools/                                 @cushlabs/tooling
/deploy/                                @cushlabs/infra

# ---- Build, CI, repo plumbing ----
/Cargo.toml                             @cushlabs/maintainers
/Cargo.lock                             @cushlabs/maintainers
/Makefile                               @cushlabs/maintainers
/rust-toolchain.toml                    @cushlabs/maintainers
/.devcontainer/                         @cushlabs/maintainers
/.github/                               @cushlabs/maintainers
/.github/workflows/                     @cushlabs/maintainers @cushlabs/security

# ---- Docs ----
/docs/                                  @cushlabs/docs
/README.md                              @cushlabs/docs @cushlabs/maintainers
/REPO_STRUCTURE.md                      @cushlabs/docs @cushlabs/maintainers
/CONTRIBUTING.md                        @cushlabs/maintainers
/CODE_OF_CONDUCT.md                     @cushlabs/maintainers

# ---- Spec (require two approvals via branch protection rule) ----
/docs/credara-technical-spec.md          @cushlabs/spec-owners @cushlabs/maintainers

# ---- Security-critical paths (require two approvals via branch protection rule) ----
/SECURITY.md                            @cushlabs/security
**/crypto/**                            @cushlabs/security
**/udap/**                              @cushlabs/security
**/spiffe/**                            @cushlabs/security
**/signature/**                         @cushlabs/security
**/auth/**                              @cushlabs/security
